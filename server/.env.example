# Copy to .env and fill in. The server reads these from the environment.

DATABASE_URL=postgresql://clpr:clpr@localhost:5432/clpr

# Redis (Render Key Value). Optional: caching + rate limiting no-op when unset.
REDIS_URL=redis://localhost:6379/0

# Shared secret required as X-API-Key on /api/* (except /api/health). Empty = the
# check is disabled. The frontend proxy injects the same value server-side.
BACKEND_API_KEY=
# Requests/min per user (or per IP when anonymous); 0 disables. Needs Redis.
RATE_LIMIT_PER_MIN=120

# Dev bypass: skip sign-in, treat every request as one local user. OFF by default;
# real OAuth sign-in is always required unless you set this to "on". NEVER in production.
DEV_AUTH=

# Signs the session cookie. Generate: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me
# Set true only when served over HTTPS (production).
SESSION_HTTPS_ONLY=false

# Public origin of the Next.js app. OAuth redirect_uri and the post-login landing
# are built from this. In dev the app runs on :3000 and proxies /api to the backend.
OAUTH_REDIRECT_BASE=http://localhost:3000
POST_LOGIN_REDIRECT=/

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (https://github.com/settings/developers)
# Authorization callback URL: http://localhost:3000/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- AI gists ---
# Generation (only needed where you RUN the build; not at request time).
# Pick a provider by model: claude-* -> anthropic, gpt-*/o-* -> openai. LLM_PROVIDER
# is optional (inferred from the model id when blank). Set the key for your provider.
LLM_MODEL=claude-opus-4-8
LLM_PROVIDER=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GIST_EVAL_THRESHOLD=0.6

# Ingest API: set GIST_ADMIN_TOKEN on the SERVER to enable POST /api/admin/gists
# (empty = endpoints disabled). Use the same token from the local build's --push.
GIST_ADMIN_TOKEN=
# Default remote target for `python -m app.gists.build --push` (the local side).
GIST_PUSH_URL=
