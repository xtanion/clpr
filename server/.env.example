# Copy to .env and fill in. The server reads these from the environment.

DATABASE_URL=postgresql://clpr:clpr@localhost:5432/clpr

# Dev bypass: skip sign-in, treat every request as one local user. OFF by default;
# real OAuth sign-in is always required unless you set this to "on". NEVER in production.
DEV_AUTH=

# Signs the session cookie. Generate: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me
# Set true only when served over HTTPS (production).
SESSION_HTTPS_ONLY=false

# Public origin of the Next.js app. OAuth redirect_uri and the post-login landing
# are built from this. In dev the app runs on :3000 and proxies /api to the backend.
OAUTH_REDIRECT_BASE=http://localhost:3000
POST_LOGIN_REDIRECT=/

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (https://github.com/settings/developers)
# Authorization callback URL: http://localhost:3000/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
